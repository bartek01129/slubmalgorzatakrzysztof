# ⚠️ UWAGA: każda zmienna VITE_* jest WKOMPILOWANA do publicznego bundla JS.
# To NIE jest miejsce na sekrety. NIGDY nie wpisuj tu CLOUDINARY_API_SECRET
# ani API_KEY — te trzyma wyłącznie backend (backend/.env).

# Hasło wejścia na stronę (schemat: data ślubu DDMMYYYY). Miękka bramka — trafia do bundla.
VITE_PASSWORD=19102026

# Cloudinary — publiczne dane do UPLOADU unsigned prosto z przeglądarki.
# Utwórz w Cloudinary preset UNSIGNED (Settings → Upload → Add upload preset).
VITE_CLOUDINARY_CLOUD_NAME=twoja_nazwa_chmury
VITE_CLOUDINARY_UPLOAD_PRESET=twoj_unsigned_preset

# Tag doklejany do każdego uploadu — MUSI = GALLERY_TAG w backendzie
# i = tag ustawiony w upload presecie Cloudinary.
VITE_GALLERY_TAG=mk2026
