PORT=3001

# Dev: http://localhost:5173 · Prod: https://twoja-domena — źródło dla CORS.
FRONTEND_URL=http://localhost:5173

# Katalog danych (originals/, web/, thumbs/, photos.json). Musi być na trwałym
# wolumenie i JEDNYM filesystemie (rename plików ma być atomowy).
DATA_DIR=/data/photos

# Twardy limit liczby zdjęć w galerii — po nim upload zwraca 409.
MAX_PHOTOS=1000

# Maksymalny rozmiar pojedynczego pliku w MB (upload powyżej → 413).
MAX_UPLOAD_MB=15

# Token administratora do DELETE (nagłówek X-Admin-Token). Bez niego kasowanie
# jest wyłączone — ustaw długi, losowy sekret. Brak wartości = brak kasowania.
ADMIN_TOKEN=
